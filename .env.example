# Upstream Hermes image used as the base for containers/hermes/Dockerfile.
# Replace this with the official registry path when using a remote image.
HERMES_IMAGE=hermes:latest

# Local image name produced by docker compose build.
HERMES_SETUP_IMAGE=dudkin-garage/hermes-setup:local

# Optional 1Password settings passed into the container.
OP_ACCOUNT=
OP_SERVICE_ACCOUNT_TOKEN=
