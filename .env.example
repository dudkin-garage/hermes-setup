# Upstream Hermes image used as the base for containers/hermes/Dockerfile.
HERMES_IMAGE=nousresearch/hermes-agent:latest

# Local image name produced by docker compose build.
HERMES_SETUP_IMAGE=dudkin-garage/hermes-setup:local

# Host directory mounted into the container at /opt/data.
HERMES_DATA_DIR=${HOME}/.hermes

# Default command. Use `setup` for first-time configuration or `gateway run` for service mode.
HERMES_COMMAND=gateway run

# VPS SSH endpoint used by `make tunnel`.
VPS_HOST=
VPS_SSH_USER=worker
VPS_SSH_PORT=22

# Docker-published Hermes ports on the VPS. Keep these loopback-only and use SSH tunnels for access.
HERMES_API_BIND_HOST=127.0.0.1
HERMES_DASHBOARD_BIND_HOST=127.0.0.1

# Gateway API server. Port 8642 is used by Hermes for OpenAI-compatible API access.
HERMES_API_HOST_PORT=8642
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_KEY=change-me-minimum-8-chars
API_SERVER_CORS_ORIGINS=http://127.0.0.1:19119,http://localhost:19119

# Dashboard. Port 9119 is used by the Hermes web dashboard.
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST_PORT=9119
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_INSECURE=1

# Local SSH forward ports opened by `make tunnel`.
HERMES_TUNNEL_LOCAL_HOST=127.0.0.1
HERMES_TUNNEL_API_LOCAL_PORT=18642
HERMES_TUNNEL_DASHBOARD_LOCAL_PORT=19119
HERMES_TUNNEL_REMOTE_HOST=127.0.0.1

# Reverse tunnel ports for the VPS Docker bridge, used by `make tunnel-reverse`.
HERMES_REVERSE_BIND_HOST=172.17.0.1
HERMES_REVERSE_API_PORT=18642
HERMES_REVERSE_DASHBOARD_PORT=19119

# Optional UID/GID mapping for Linux/NAS bind mounts.
HERMES_UID=
HERMES_GID=
PUID=
PGID=

# Optional 1Password settings passed into the container.
OP_ACCOUNT=
OP_SERVICE_ACCOUNT_TOKEN=
